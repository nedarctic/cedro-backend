generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model Tour {
  id        String    @id @default(uuid())
  title     String
  bookings  Booking[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt()
}

model Booking {
  id        String   @id @default(uuid())
  name      String
  email     String
  tourId    String
  tour      Tour     @relation(fields: [tourId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt()
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique()
  password     String
  refreshToken String?
  role         UserRole @default(ADMIN)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt()
}

enum UserRole {
  ADMIN
  SUPER_ADMIN
}
